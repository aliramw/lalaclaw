<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.lalaclaw.app</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/LALACLAW</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd /ABSOLUTE/PATH/TO/LALACLAW &amp;&amp; npm run lalaclaw:start</string>
    </array>

    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/LALACLAW/logs/lalaclaw-launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/LALACLAW/logs/lalaclaw-launchd.err.log</string>
  </dict>
</plist>
