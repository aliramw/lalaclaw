# LalaClaw local configuration example
# Copy to .env.local and adjust values if you do not want to use `npm run lalaclaw:init`.

# Development server bindings
HOST=127.0.0.1
PORT=3000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173

# Runtime profile
# Set to 1 to force mock mode even if a local OpenClaw config exists.
COMMANDCENTER_FORCE_MOCK=0
# Optional absolute path to the OpenClaw CLI for launchd and other non-interactive environments.
# OPENCLAW_BIN=/absolute/path/to/openclaw

# Remote OpenClaw gateway settings
# Leave OPENCLAW_BASE_URL and OPENCLAW_API_KEY empty to use local-openclaw auto-discovery.
# OPENCLAW_BASE_URL=https://your-openclaw-gateway
# OPENCLAW_API_KEY=your-token
OPENCLAW_MODEL=openclaw
OPENCLAW_AGENT_ID=main
OPENCLAW_API_STYLE=chat
OPENCLAW_API_PATH=/v1/chat/completions

# Optional browser access protection for public or shared deployments.
# Set COMMANDCENTER_ACCESS_MODE=token and provide one or more newline/comma-separated tokens
# directly or through a file path. The browser exchanges a token for an httpOnly cookie.
# COMMANDCENTER_ACCESS_MODE=token
# COMMANDCENTER_ACCESS_TOKENS=replace-with-a-long-random-token
# COMMANDCENTER_ACCESS_TOKENS_FILE=/absolute/path/to/ACCESS_TOKENS.txt
