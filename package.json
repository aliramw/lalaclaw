{
  "name": "lalaclaw",
  "version": "2026.3.21-2",
  "description": "Agent command center prototype for an OpenClaw-style operator cockpit.",
  "main": "server.js",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "bin": {
    "lalaclaw": "bin/lalaclaw.js"
  },
  "files": [
    "bin/",
    "deploy/macos/",
    "dist/",
    "docs/",
    "server/",
    "shared/",
    ".env.local.example",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "server.js"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:all": "node ./bin/lalaclaw.js dev",
    "dev:backend": "node ./bin/lalaclaw.js backend",
    "dev:frontend": "node ./bin/lalaclaw.js frontend",
    "doctor": "node ./bin/lalaclaw.js doctor",
    "lalaclaw:init": "node ./bin/lalaclaw.js init",
    "lalaclaw:start": "node ./bin/lalaclaw.js start",
    "lint": "eslint .",
    "pack:release": "mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepack": "npm run build",
    "start": "node server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:openclaw:onboarding:smoke": "node ./scripts/openclaw-onboarding-smoke.cjs",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aliramw/lalaclaw.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aliramw/lalaclaw/issues"
  },
  "homepage": "https://github.com/aliramw/lalaclaw#readme",
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "monaco-editor": "^0.55.1",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "vite": "^7.1.3",
    "vitest": "^4.1.0"
  }
}
